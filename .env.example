# Telegram API credentials — obtain at https://my.telegram.org
API_ID=
API_HASH=

# PostgreSQL connection string
# Use "postgres" as host inside Docker Compose, "localhost" for local runs
DATABASE_URL=postgresql://tgproxy:tgproxy@postgres:5432/tgproxy

# Path to config file (optional, default: config.yaml)
# CONFIG_PATH=config.yaml

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
